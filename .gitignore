# ===================================================================
# التبعيات ومخرجات البناء (Dependencies & Build Artifacts)
# ===================================================================
# يتم تجاهلها لأنها تُثبّت على السيرفر أو الجهاز المحلي، ولا يجب تخزينها في المستودع
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*


# ===================================================================
# ملفات الإعدادات والملفات السرية (Configuration & Secret Files)
# ===================================================================
# هذه الملفات تحتوي على معلومات حساسة (كلمات مرور، مفاتيح API).
# ملف .env.example لا يتم تجاهله لأنه قالب للآخرين ولا يحتوي على أسرار.
backend/.env
backend/.env.prod


# ===================================================================
# السجلات وملفات الجلسات (Logs & Session Files)
# ===================================================================
# يتم إنشاؤها أثناء تشغيل التطبيق وتخص بيئة معينة.
backend/debug.log
backend/sessions/


# ===================================================================
# قاعدة بيانات التطوير المحلية (Local Development Database)
# ===================================================================
# قاعدة بيانات الإنتاج هي MySQL. هذا السطر يتجاهل قاعدة بيانات SQLite المستخدمة في التطوير.
backend/data/
backend/data/*.sqlite
backend/data/*.sqlite-journal


# ===================================================================
# محتوى المستخدمين (User-Generated Content - الأهم)
# ===================================================================
# هذا هو أهم سطر لمنع حذف الوسائط المرفوعة من قبل المستخدمين.
# نحن نتجاهل المجلد بالكامل. يجب إنشاء هذا المجلد على السيرفر
# ومحتوياته يجب ألا يتم تعقبها بواسطة Git نهائياً.
frontend/public/uploads/


# ===================================================================
# ملفات نظام التشغيل (Operating System Files)
# ===================================================================
# ملفات غير ضرورية يتم إنشاؤها بواسطة macOS و Windows.
.DS_Store
Thumbs.db