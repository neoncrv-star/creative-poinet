<%- include('../partials/header') %>

<style>
    .blog-page-body {
        background-color: var(--bg-color);
    }
    
    .blog-hero {
        padding: 180px 0 100px;
        background-color: var(--bg-color);
        position: relative;
        overflow: hidden;
        text-align: center;
    }
    
    .blog-hero .eyebrow {
        display: inline-block;
        color: var(--primary-color);
        font-size: 0.9rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 4px;
        margin-bottom: 25px;
        padding: 8px 20px;
        border: 1px solid rgba(255, 49, 49, 0.3);
        border-radius: 50px;
        background: rgba(255, 49, 49, 0.05);
    }
    
    .blog-hero .page-title {
        font-size: clamp(3rem, 8vw, 5rem);
        font-weight: 900;
        line-height: 1.1;
        color: var(--text-color);
        margin-bottom: 30px;
    }
    
    .blog-grid-section {
        padding: 80px 0 120px;
        background-color: var(--bg-color);
    }
    
    .blog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 40px;
    }
    
    .blog-card {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
        height: 100%;
        display: flex;
        flex-direction: column;
    }
    
    .blog-card:hover {
        transform: translateY(-10px);
        border-color: var(--primary-color);
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    }
    
    .blog-card-image {
        width: 100%;
        height: 240px;
        object-fit: cover;
        border-bottom: 1px solid var(--border-color);
    }
    
    .blog-card-content {
        padding: 30px;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }
    
    .blog-card-date {
        font-size: 0.85rem;
        color: var(--primary-color);
        margin-bottom: 15px;
        font-weight: 600;
    }
    
    .blog-card-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--text-color);
        margin-bottom: 15px;
        line-height: 1.3;
    }
    
    .blog-card-excerpt {
        font-size: 1rem;
        color: var(--accent-color);
        margin-bottom: 25px;
        line-height: 1.6;
    }
    
    .blog-card-link {
        margin-top: auto;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--text-color);
        font-weight: 700;
        transition: color 0.3s;
    }
    
    .blog-card:hover .blog-card-link {
        color: var(--primary-color);
    }
</style>

<main class="blog-page-body">
    <!-- Blog Hero Section -->
    <section class="blog-hero">
        <div class="container">
            <div class="hero-content" data-gsap="fade-up">
                <span class="eyebrow"><%= typeof isEn !== 'undefined' && isEn ? 'Insights & Stories' : 'رؤى وقصص' %></span>
                <h1 class="page-title">
                    <% if(typeof isEn !== 'undefined' && isEn) { %>
                        Creative Point<br>Blog
                    <% } else { %>
                        مدونة<br>نقطة إبداعية
                    <% } %>
                </h1>
                <p class="page-desc">
                    <% if(typeof isEn !== 'undefined' && isEn) { %>
                        Discover the latest trends in design, technology, and branding.
                    <% } else { %>
                        اكتشف أحدث الاتجاهات في التصميم، التكنولوجيا، وبناء العلامات التجارية.
                    <% } %>
                </p>
            </div>
        </div>
    </section>

    <!-- Blog Grid Section -->
    <section class="blog-grid-section">
        <div class="container">
            <div class="blog-grid">
                <% if (posts && posts.length > 0) { %>
                    <% posts.forEach((post, index) => { %>
                        <article class="blog-card" data-gsap="fade-up">
                            <% if(post.image) { %>
                                <img src="<%= assetPath(post.image) %>" alt="<%= post.title %>" class="blog-card-image">
                            <% } %>
                            <div class="blog-card-content">
                                <span class="blog-card-date">
                                    <i class="ri-calendar-line"></i> 
                                    <%= new Date(post.date).toLocaleDateString(typeof isEn !== 'undefined' && isEn ? 'en-US' : 'ar-EG', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                                </span>
                                <h2 class="blog-card-title"><%= post.title %></h2>
                                <p class="blog-card-excerpt"><%= post.excerpt %></p>
                                <a href="/blog/<%= post.id %>" class="blog-card-link">
                                    <%= typeof isEn !== 'undefined' && isEn ? 'Read More' : 'اقرأ المزيد' %>
                                    <i class="ri-arrow-<%= typeof isEn !== 'undefined' && isEn ? 'right' : 'left' %>-line"></i>
                                </a>
                            </div>
                        </article>
                    <% }) %>
                <% } else { %>
                    <div class="no-posts" style="text-align: center; grid-column: 1/-1; padding: 100px 0;">
                        <p><%= typeof isEn !== 'undefined' && isEn ? 'No articles found.' : 'لا توجد مقالات حالياً.' %></p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</main>

<%- include('../partials/footer') %>
