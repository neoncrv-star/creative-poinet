<%- include('../partials/header') %>

<style>
    .blog-page-body {
        background-color: var(--bg-color);
    }
    
    .post-detail-page {
        padding-top: 150px;
        padding-bottom: 100px;
        background-color: var(--bg-color);
    }
    
    .post-header {
        max-width: 900px;
        margin: 0 auto 60px;
        text-align: center;
    }
    
    .post-title {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 900;
        color: var(--text-color);
        margin-bottom: 25px;
        line-height: 1.1;
    }
    
    .post-meta {
        display: flex;
        justify-content: center;
        gap: 20px;
        color: var(--accent-color);
        font-size: 0.9rem;
    }
    
    .post-featured-image {
        width: 100%;
        max-height: 600px;
        object-fit: cover;
        border-radius: 20px;
        margin-bottom: 60px;
    }
    
    .post-content {
        max-width: 800px;
        margin: 0 auto;
        font-size: 1.15rem;
        line-height: 1.8;
        color: var(--text-color);
    }
    
    .post-content p {
        margin-bottom: 30px;
    }
    
    .post-content h2, .post-content h3 {
        margin: 50px 0 25px;
        color: var(--text-color);
    }
    
    .back-to-blog {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 40px;
        color: var(--accent-color);
        transition: color 0.3s;
    }
    
    .back-to-blog:hover {
        color: var(--primary-color);
    }
</style>

<main class="post-detail-page">
    <div class="container">
        <a href="/blog" class="back-to-blog">
            <i class="ri-arrow-<%= typeof isEn !== 'undefined' && isEn ? 'left' : 'right' %>-line"></i>
            <%= typeof isEn !== 'undefined' && isEn ? 'Back to Blog' : 'العودة للمدونة' %>
        </a>

        <article class="post-full-content">
            <header class="post-header" data-gsap="fade-up">
                <h1 class="post-title"><%= post.title %></h1>
                <div class="post-meta">
                    <span class="post-date">
                        <i class="ri-calendar-line"></i>
                        <%= new Date(post.date).toLocaleDateString(typeof isEn !== 'undefined' && isEn ? 'en-US' : 'ar-EG', { year: 'numeric', month: 'long', day: 'numeric' }) %>
                    </span>
                    <% if(post.author) { %>
                        <span class="post-author">
                            <i class="ri-user-line"></i>
                            <%= post.author %>
                        </span>
                    <% } %>
                </div>
            </header>

            <% if(post.image) { %>
                <img src="<%= assetPath(post.image) %>" alt="<%= post.title %>" class="post-featured-image" data-gsap="fade-up">
            <% } %>

            <div class="post-content" data-gsap="fade-up">
                <%- post.content %>
            </div>
        </article>
    </div>
</main>

<%- include('../partials/footer') %>
