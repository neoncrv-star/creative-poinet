<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <% 
        // منطق الـ SEO المختصر
        let activeSeo = (typeof globalSeo !== 'undefined' && globalSeo) ? globalSeo : (typeof seo !== 'undefined' ? seo : null);
        let siteTitle = activeSeo ? activeSeo.siteTitle : 'نقطة إبداعية';
        let pageTitle = (typeof title !== 'undefined') ? title : '';
        let finalTitle = pageTitle ? `${pageTitle} | ${siteTitle}` : siteTitle;
    %>

    <title><%= finalTitle %></title>
    
    <!-- 1. مكتبات الخطوط والأيقونات -->
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link rel="icon" type="image/x-icon" href="/210.png">

    <!-- 2. تحميل مكتبة GSAP (هذا هو الحل للخطأ الذي ظهر عندك) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/ScrollTrigger.min.js"></script>

    <!-- 3. التنسيقات الأساسية فقط (يفضل نقل الباقي لملف CSS خارجي) -->
    <style>
        @font-face { font-family: 'TheSansArabic'; src: url('/fonts/TheSansArabic-Plain.otf'); font-display: swap; }
        :root { --bg-color: #000; --text-color: #fff; --primary-color: #ff3131; --font-family: 'TheSansArabic', sans-serif; }
        body { background: var(--bg-color); color: var(--text-color); font-family: var(--font-family); margin:0; }
        
        /* إظهار العناصر إجبارياً لحل مشكلة الاختفاء */
        .cpoint-service-item, .partner-item, .cpoint-project-item, [data-gsap="fade-up"] {
            opacity: 1 !important; visibility: visible !important; transform: none !important;
        }

        #cpoint-preloader { position: fixed; inset: 0; background: #000; z-index: 9999; display: flex; align-items: center; justify-content: center; }
        .spinner { width: 50px; height: 50px; border: 3px solid #333; border-top-color: #ff3131; border-radius: 50%; animation: spin 1s linear infinite; }
        @keyframes spin { to { transform: rotate(360deg); } }
        .main-header { position: fixed; top: 0; width: 100%; z-index: 1000; background: rgba(0,0,0,0.8); backdrop-filter: blur(10px); padding: 15px 0; }
        .header-container { width: 90%; max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
        .header-nav { display: flex; gap: 20px; }
        .nav-link { color: #fff; text-decoration: none; font-size: 0.9rem; }
        .header-logo-img { height: 40px; }
    </style>
</head>
<body>

    <!-- Preloader -->
    <div id="cpoint-preloader"><div class="spinner"></div></div>

    <header class="main-header">
        <div class="header-container">
            <div class="logo">
                <a href="/"><img src="/210.png" class="header-logo-img"></a>
            </div>
            <nav class="header-nav">
                <% if(typeof isEn !== 'undefined' && isEn) { %>
                    <a href="/en#journey" class="nav-link">Journey</a>
                    <a href="/en/portfolio" class="nav-link">Work</a>
                    <a href="/" class="nav-link">العربية</a>
                <% } else { %>
                    <a href="/#journey" class="nav-link">رحلتها</a>
                    <a href="/services" class="nav-link">خدماتها</a>
                    <a href="/portfolio" class="nav-link">أعمالها</a>
                    <a href="/en" class="nav-link">English</a>
                <% } %>
            </nav>
        </div>
    </header>

    <div style="height: 80px;"></div>

    <script>
        // إخفاء الـ Preloader
        window.addEventListener('load', () => {
            document.getElementById('cpoint-preloader').style.display = 'none';
        });
    </script>