<%- include('layout-header') %>

<div class="admin-content-inner">
    <div class="admin-topbar-actions" style="margin-bottom: 2rem; display: flex; justify-content: space-between; align-items: center;">
        <h2 style="font-weight: 700; color: var(--secondary-color);"><%= post ? 'تعديل المقال' : 'إضافة مقال جديد' %></h2>
        <a href="/admin/blog" class="btn btn-secondary" style="background: #eee; color: var(--text-main);">
            <i class="fas fa-arrow-right"></i> إلغاء والعودة
        </a>
    </div>

    <form action="/admin/blog/<%= post ? 'edit/' + post.id : 'add' %>" method="POST" enctype="multipart/form-data">
        <div class="form-layout" style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
            <!-- Main Content Column -->
            <div class="form-main-col">
                <div class="admin-card">
                    <h3 style="margin-bottom: 1.5rem; color: var(--secondary-color); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <i class="fas fa-edit"></i> محتوى المقال
                    </h3>
                    
                    <div class="form-group">
                        <label><i class="fas fa-heading"></i> عنوان المقال</label>
                        <input type="text" name="title" value="<%= post ? post.title : '' %>" placeholder="أدخل عنواناً جذاباً للمقال..." required>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-quote-right"></i> مقتطف قصير</label>
                        <textarea name="excerpt" rows="3" placeholder="وصف مختصر يظهر في قائمة المقالات..." required><%= post ? post.excerpt : '' %></textarea>
                        <small style="color: var(--text-muted);">يفضل أن يكون بين 100-150 حرف.</small>
                    </div>

                    <div class="form-group">
                        <label><i class="fas fa-file-alt"></i> نص المقال</label>
                        <div id="blog-content-editor" style="min-height: 400px; background: #fff; direction: rtl;"></div>
                        <textarea name="content" id="blog-content-editor-src" style="display: none;"><%= post ? post.content : '' %></textarea>
                    </div>
                </div>

                <!-- SEO Section -->
                <div class="admin-card">
                    <h3 style="margin-bottom: 1.5rem; color: var(--secondary-color); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <i class="fas fa-search"></i> تحسين محركات البحث (SEO)
                    </h3>
                    
                    <div class="form-group">
                        <label>عنوان السيو (SEO Title)</label>
                        <input type="text" name="seoTitle" value="<%= post ? post.seoTitle : '' %>" placeholder="اتركه فارغاً لاستخدام عنوان المقال">
                    </div>

                    <div class="form-group">
                        <label>وصف السيو (Meta Description)</label>
                        <textarea name="seoDescription" rows="3" placeholder="وصف المقال لمحركات البحث..."><%= post ? post.seoDescription : '' %></textarea>
                    </div>

                    <div class="form-group">
                        <label>كلمات مفتاحية</label>
                        <input type="text" name="seoKeywords" value="<%= post ? post.seoKeywords : '' %>" placeholder="كلمة1, كلمة2, كلمة3...">
                    </div>
                </div>
            </div>

            <!-- Sidebar Column -->
            <div class="form-side-col">
                <div class="admin-card">
                    <h3 style="margin-bottom: 1.5rem; color: var(--secondary-color); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <i class="fas fa-paper-plane"></i> النشر
                    </h3>
                    <div class="form-group">
                        <label>تاريخ النشر</label>
                        <input type="date" name="date" value="<%= post ? post.date : new Date().toISOString().split('T')[0] %>">
                    </div>
                    <div class="form-group">
                        <label>الرابط المختصر (Slug)</label>
                        <input type="text" name="slug" value="<%= post ? post.slug : '' %>" placeholder="اتركه فارغاً للتوليد التلقائي">
                        <small style="color: var(--text-muted); display: block;">للرابط (URL). أحرف إنجليزية فقط.</small>
                    </div>
                    <div class="form-group" style="background: #f8f9fa; padding: 10px; border-radius: 8px;">
                        <label style="display: flex; align-items: center; gap: 10px; cursor: pointer; margin-bottom: 0;">
                            <input type="checkbox" name="is_active" <%= (!post || post.is_active) ? 'checked' : '' %> style="width: auto;">
                            <span>نشط (يظهر في المدونة)</span>
                        </label>
                    </div>
                    <button type="submit" class="btn btn-primary btn-block" style="width: 100%; justify-content: center; padding: 1rem;">
                        <i class="fas fa-save"></i> <%= post ? 'حفظ التغييرات' : 'نشر المقال' %>
                    </button>
                </div>

                <div class="admin-card">
                    <h3 style="margin-bottom: 1.5rem; color: var(--secondary-color); border-bottom: 1px solid #eee; padding-bottom: 10px;">
                        <i class="fas fa-image"></i> الصورة البارزة
                    </h3>
                    
                    <% if (post && post.image) { %>
                        <div class="current-image" style="margin-bottom: 1rem; border: 1px solid #eee; border-radius: 8px; overflow: hidden;">
                            <img src="<%= assetPath(post.image) %>" alt="Current Image" style="width: 100%; height: auto; display: block;">
                        </div>
                    <% } else { %>
                        <div class="no-image" style="background: #f8f9fa; height: 150px; display: flex; align-items: center; justify-content: center; border: 2px dashed #ddd; border-radius: 8px; margin-bottom: 1rem; color: var(--text-muted);">
                            <i class="fas fa-image fa-3x"></i>
                        </div>
                    <% } %>

                    <div class="file-upload-wrapper" style="display:flex; flex-direction: column; gap: 8px;">
                        <label class="btn btn-outline" for="blog-image" style="width: 100%; border: 2px dashed var(--primary-color); color: var(--primary-color); justify-content: center; cursor: pointer;">
                            <i class="fas fa-cloud-upload-alt"></i> اختر من جهازك
                            <input type="file" name="image" id="blog-image" accept="image/*" style="display:none" onchange="updateFileName(this)">
                        </label>
                        <button type="button" class="btn btn-secondary" style="justify-content:center;" onclick="openUploadsBrowser('blog')" id="open-server-blog-btn">
                            <i class="fas fa-folder-open"></i> اختيار من الخادم
                        </button>
                        <input type="hidden" name="existingImage" id="existingImageBlog" value="<%= post && post.image ? post.image : '' %>">
                        <div id="file-name" style="margin-top: 10px; font-size: 0.85rem; color: var(--primary-color); text-align: center;"></div>
                        <small style="display: block; margin-top: 10px; color: var(--text-muted); text-align: center;">📐 المقاس الموصى به: 1200×630 بكسل (نسبة 1.91:1)</small>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Uploads Browser Modal -->
<div id="uploadsBrowserModal" class="admin-modal">
  <div class="modal-content" style="max-width:800px;">
    <span class="close-modal" onclick="closeUploadsBrowser()">&times;</span>
    <h3 style="margin-bottom:10px;color:var(--secondary-color)"><i class="fas fa-folder-open"></i> استعراض الصور على الخادم</h3>
    <div style="display:flex;gap:8px;align-items:center;margin-bottom:10px;">
        <input id="uploadsSearch" type="text" placeholder="ابحث بالاسم..." style="flex:1;padding:8px;border:1px solid #ddd;border-radius:8px;">
        <button class="btn" onclick="refreshUploads()">تحديث</button>
    </div>
    <div id="uploadsGrid" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:10px;max-height:60vh;overflow:auto;"></div>
  </div>
  <style>
    #uploadsGrid img{width:100%;height:100px;object-fit:cover;border-radius:8px;border:1px solid #eee}
    .upload-tile{cursor:pointer;position:relative}
    .upload-tile span{position:absolute;bottom:0;left:0;right:0;background:rgba(0,0,0,0.5);color:#fff;font-size:.75rem;padding:2px 4px;border-radius:0 0 8px 8px;direction:ltr}
  </style>
</div>

<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
var quill = new Quill('#blog-content-editor', {
    theme: 'snow',
    placeholder: 'اكتب محتوى المقال هنا...',
    modules: {
        toolbar: [
            [{ 'header': [1, 2, 3, 4, 5, 6, false] }],
            [{ 'font': [] }],
            [{ 'size': ['small', false, 'large', 'huge'] }],
            ['bold', 'italic', 'underline', 'strike'],
            [{ 'color': [] }, { 'background': [] }],
            [{ 'align': [] }],
            [{ 'direction': 'rtl' }],
            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
            [{ 'indent': '-1' }, { 'indent': '+1' }],
            ['blockquote', 'code-block'],
            ['link', 'image', 'video'],
            ['clean']
        ]
    }
});

var existingContent = document.querySelector('#blog-content-editor-src');
if (existingContent && existingContent.value) {
    quill.root.innerHTML = existingContent.value;
}

var form = document.querySelector('form[action]');
if (form) {
    form.onsubmit = function() {
        existingContent.value = quill.root.innerHTML;
    };
}

function updateFileName(input) {
    const fileName = input.files[0]?.name;
    document.getElementById('file-name').textContent = fileName ? `المجلد المختار: ${fileName}` : '';
}

let uploadsTarget = null;
async function openUploadsBrowser(target){
    uploadsTarget = target;
    document.getElementById('uploadsBrowserModal').style.display='block';
    await refreshUploads();
}
function closeUploadsBrowser(){
    document.getElementById('uploadsBrowserModal').style.display='none';
}
async function refreshUploads(){
    const q = document.getElementById('uploadsSearch').value?.trim().toLowerCase();
    const res = await fetch('/admin/uploads/list');
    const json = await res.json();
    const grid = document.getElementById('uploadsGrid');
    grid.innerHTML='';
    (json.files||[])
      .filter(f => !q || f.name.toLowerCase().includes(q))
      .forEach(f=>{
        const div = document.createElement('div');
        div.className='upload-tile';
        div.onclick = ()=> selectExistingImage(f.url);
        div.innerHTML = `<img src="${f.url}" alt="${f.name}"><span>${f.name}</span>`;
        grid.appendChild(div);
      });
}
function selectExistingImage(url){
    if(uploadsTarget==='blog'){
        document.getElementById('existingImageBlog').value = url;
        document.getElementById('file-name').textContent = `المحدد: ${url.split('/').pop()}`;
    }
    closeUploadsBrowser();
}
</script>

<style>
@media (max-width: 992px) {
    .form-layout {
        grid-template-columns: 1fr !important;
    }
    .form-side-col {
        order: -1;
    }
}
</style>

<%- include('layout-footer') %>
