<% const isEn = false; %>
<%- include('partials/header', { isEn: isEn }) %>

<link rel="preload" href="/css/hero.css?v=<%= assetVersion %>" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="/css/journey.css?v=<%= assetVersion %>" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="/css/services-stacked.css?v=<%= assetVersion %>" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="/css/portfolio-slider.css?v=<%= assetVersion %>" as="style" onload="this.onload=null;this.rel='stylesheet'">
<link rel="preload" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript>
    <link rel="stylesheet" href="/css/hero.css?v=<%= assetVersion %>">
    <link rel="stylesheet" href="/css/journey.css?v=<%= assetVersion %>">
    <link rel="stylesheet" href="/css/services-stacked.css?v=<%= assetVersion %>">
    <link rel="stylesheet" href="/css/portfolio-slider.css?v=<%= assetVersion %>">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
</noscript>

<style>
    :root {
        --service-overlay-opacity: <%= (globalSeo && globalSeo.serviceOverlayOpacity !== undefined) ? globalSeo.serviceOverlayOpacity : 0.8 %>;
        --service-image-brightness: <%= (globalSeo && globalSeo.serviceImageBrightness !== undefined) ? globalSeo.serviceImageBrightness : 0.5 %>;
        --slider-height: <%= (globalSeo && globalSeo.sliderHeight) ? globalSeo.sliderHeight : '500px' %>;
    }

    .portfolio-swiper {
        height: var(--slider-height) !important;
    }

    .project-card {
        height: 100% !important;
    }

    .project-card img, .project-card video {
        height: 100% !important;
        object-fit: cover !important;
    }
</style>

<main>

    <!-- ========================= Hero Section ========================== -->
    <%
        var seo = globalSeo;
        var heroBgStyle = (seo && seo.heroBackgroundImage) ? `style="background-image: url('${assetPath(seo.heroBackgroundImage)}');"` : "";
    %>
    <section class="hero-modern-section" <%- heroBgStyle %>>
        <%
            var mode    = seo && seo.heroVideoMode ? seo.heroVideoMode.toLowerCase() : 'none';
            var rawUrl  = seo && seo.heroVideoUrl  ? seo.heroVideoUrl.trim() : '';
            var fileVal = seo && seo.heroVideoFile ? seo.heroVideoFile : '';
            var heroType  = 'none';
            var heroSrc   = '';
            var heroEmbed = '';

            if (mode !== 'none') {
                var ytMatch = rawUrl ? rawUrl.match(/(?:v=|youtu\.be\/|embed\/)([A-Za-z0-9_-]{6,})/) : null;
                var vMatch  = rawUrl ? rawUrl.match(/vimeo\.com\/(\d+)/) : null;
                if (mode === 'file' && fileVal) {
                    heroType = 'video';
                    heroSrc  = assetPath(fileVal);
                } else if ((mode === 'youtube' || (mode === 'url' && ytMatch && ytMatch[1])) && rawUrl) {
                    var ytId = ytMatch && ytMatch[1] ? ytMatch[1] : null;
                    if (ytId) {
                        heroType  = 'embed';
                        heroEmbed = 'https://www.youtube.com/embed/' + ytId + '?autoplay=1&mute=1&controls=0&loop=1&playlist=' + ytId + '&showinfo=0&rel=0&modestbranding=1&playsinline=1';
                    }
                } else if ((mode === 'vimeo' || (mode === 'url' && vMatch && vMatch[1])) && rawUrl) {
                    var vId = vMatch && vMatch[1] ? vMatch[1] : null;
                    if (vId) {
                        heroType  = 'embed';
                        heroEmbed = 'https://player.vimeo.com/video/' + vId + '?autoplay=1&muted=1&background=1&loop=1&title=0&byline=0&portrait=0';
                    }
                } else if (rawUrl) {
                    heroType = 'video';
                    heroSrc  = rawUrl;
                }
            }
        %>

        <% if (heroType !== 'none') { %>
            <div class="hero-video-bg">
                <% if (heroType === 'embed') { %>
                    <iframe class="hero-video-el" src="<%= heroEmbed %>" frameborder="0" allow="autoplay; fullscreen" allowfullscreen></iframe>
                <% } else { %>
                    <video class="hero-video-el" playsinline muted loop autoplay preload="metadata">
                        <source src="<%= heroSrc %>" type="video/mp4">
                    </video>
                <% } %>
                <div class="hero-overlay"></div>
            </div>
        <% } %>

        <div class="container hero-container">
            <div class="hero-content">
                <p class="hero-eyebrow fade-in">
                    <%= seo && seo.heroSmallTitleAr ? seo.heroSmallTitleAr : 'إبداع يبدأ بنقطة' %>
                </p>
                <h1 class="hero-title fade-in">
                    <%- (seo && seo.heroMainTitleAr ? seo.heroMainTitleAr : 'وكالة إبداعية وتسويقية<br>متكاملة الخدمات').replace(/\n/g, '<br>') %>
                </h1>
                <p class="hero-description fade-in">
                    <%= seo && seo.heroDescriptionAr ? seo.heroDescriptionAr : 'ترتكز على فكرة واضحة قبل البدء بأي تنفيذ. نحن نؤمن بأن وضوح الرؤية هو أساس كل مشروع ناجح.' %>
                </p>
                <div class="hero-actions fade-in">
                    <a href="#journey" class="btn-hero-pill">
                        <%= seo && seo.heroBtnTextAr ? seo.heroBtnTextAr : 'اكتشف الرحلة' %>
                        <i class="ri-arrow-left-line"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="hero-scroll-indicator">
            <div class="mouse"><div class="wheel"></div></div>
            <span>تصفح</span>
        </div>
    </section>

    <!-- ========================= Stats Section ========================== -->
    <% if (typeof stats !== 'undefined' && stats && stats.length) { %>
    <section class="stats-section">
        <div class="stats-wrapper">
            <% stats.forEach(function(stat) { %>
                <article class="stat-item">
                    <div class="stat-value">
                        <span class="stat-number" data-target="<%= stat.value %>">0</span>
                        <% if (stat.suffix_ar) { %>
                            <span class="stat-suffix"><%= stat.suffix_ar %></span>
                        <% } %>
                    </div>
                    <p class="stat-label"><%= stat.label_ar %></p>
                </article>
            <% }); %>
        </div>
    </section>
    <% } %>

    <!-- ========================= Journey Section ========================== -->
    <section id="journey" class="journey-scroll-section">
        <div class="journey-container" style="text-align: center;">
            <p class="journey-eyebrow" style="text-align: center;">وكالة نقطة إبداعية</p>
            <div class="journey-text-content" style="text-align: center;">
                <span class="journey-line"><%= seo && seo.journeyLine1Ar ? seo.journeyLine1Ar : 'وكالة إبداعية وتسويقية متكاملة الخدمات' %></span>
                <span class="journey-line"><%= seo && seo.journeyLine2Ar ? seo.journeyLine2Ar : 'ترتكز على فكرة واحدة واضحة قبل البدء بأي تنفيذ' %></span>
                <span class="journey-line"><%= seo && seo.journeyLine3Ar ? seo.journeyLine3Ar : 'في عالم مزدحم بالضجيج البصري والإعلاني' %></span>
                <span class="journey-line"><%= seo && seo.journeyLine4Ar ? seo.journeyLine4Ar : 'لا نبدأ بالزخرفة' %></span>
                <span class="journey-line"><%= seo && seo.journeyLine5Ar ? seo.journeyLine5Ar : 'بل نبدأ بقرار استراتيجي ذكي وموحد' %></span>
                <span class="journey-line"><%= seo && seo.journeyLine6Ar ? seo.journeyLine6Ar : 'من هذه النقطة، نعيد الإبداع إلى جوهره الحقيقي' %></span>
                <span class="journey-line"><%= seo && seo.journeyLine7Ar ? seo.journeyLine7Ar : 'هوية بصرية راسخة' %></span>
                <span class="journey-line"><%= seo && seo.journeyLine8Ar ? seo.journeyLine8Ar : 'حلول تصميم احترافية' %></span>
                <span class="journey-line"><%= seo && seo.journeyLine9Ar ? seo.journeyLine9Ar : 'وتجهيزات معارض ومؤتمرات عالية الجودة' %></span>
            </div>
        </div>
    </section>

    <!-- ========================= Services Section ========================== -->
    <section id="services" class="services-stacked-section">
        <div class="services-stacked-wrapper">
            <div class="services-stacked-header">
                <p class="services-stacked-eyebrow">الخدمات</p>
                <h2 class="services-stacked-title">حلول متراكمة من الاستراتيجية إلى التنفيذ</h2>
                <p class="services-stacked-subtitle">
                    كل خدمة تمثل نقطة واضحة في المسار، تبني على ما قبلها لتشكل نظاماً إبداعياً متكاملاً يحافظ على ثباته في كل نقاط التماس.
                </p>
            </div>

            <% var servicesList = (typeof services !== 'undefined' && services) ? services : []; %>
            <% if (servicesList.length) { %>
                <div class="services-stacked-cards">
                    <% servicesList.forEach(function(service, index) { %>
                        <article class="service-stacked-card" style="--card-index:<%= index %>;">
                            <div class="service-stacked-inner">
                                <div class="service-stacked-copy">
                                    <div>
                                        <div class="service-stacked-topline">
                                            <span class="service-stacked-label">الخدمة</span>
                                            <span class="service-stacked-index"><%= (index + 1).toString().padStart(2, '0') %></span>
                                        </div>
                                        <h3 class="service-stacked-heading">
                                            <%= service.title_ar || service.title_en || '' %>
                                        </h3>
                                        <p class="service-stacked-text">
                                            <%= service.description_ar || service.description_en || '' %>
                                        </p>
                                        <ul class="service-stacked-tags">
                                            <% if (service.tag1_ar || service.tag1_en) { %>
                                                <li class="service-stacked-tag"><%= service.tag1_ar || service.tag1_en %></li>
                                            <% } %>
                                            <% if (service.tag2_ar || service.tag2_en) { %>
                                                <li class="service-stacked-tag"><%= service.tag2_ar || service.tag2_en %></li>
                                            <% } %>
                                            <% if (service.tag3_ar || service.tag3_en) { %>
                                                <li class="service-stacked-tag"><%= service.tag3_ar || service.tag3_en %></li>
                                            <% } %>
                                        </ul>
                                    </div>
                                    <div class="service-stacked-meta">
                                        <span>من الفكرة الواضحة إلى التنفيذ الملموس</span>
                                        <span class="service-stacked-meta-dot"></span>
                                    </div>
                                </div>
                                <div class="service-stacked-media">
                                    <div class="service-stacked-image-frame">
                                        <% if (service.image) { %>
                                            <img class="service-stacked-image"
                                                 src="<%= assetPath(service.image) %>"
                                                 alt="<%= service.imageAlt_ar || service.title_ar || service.title_en || '' %>"
                                                 loading="lazy" decoding="async">
                                        <% } else { %>
                                            <div class="service-stacked-image-placeholder"></div>
                                        <% } %>
                                        <div class="service-stacked-image-overlay"></div>
                                        <div class="service-stacked-image-grain"></div>
                                    </div>
                                </div>
                            </div>
                        </article>
                    <% }) %>
                </div>
            <% } else { %>
                <div class="services-stacked-empty">
                    <h3>لا توجد خدمات مضافة حالياً</h3>
                    <p>بمجرد إضافة خدمات من لوحة التحكم، ستظهر هنا كبطاقات متراكمة.</p>
                </div>
            <% } %>
        </div>
    </section>

    <!-- ========================= Portfolio Section ========================== -->
    <section id="portfolio" class="portfolio-section">
        <div class="container">
            <div class="portfolio-header" data-gsap="fade-up" style="text-align: center;">
                <h2 class="portfolio-title">أحدث المشاريع</h2>
                <p style="text-align: center;">تحويل الأفكار إلى واقع... استكشف أعمالنا</p>
            </div>

            <div class="portfolio-container" data-gsap="fade-up">
                <button class="portfolio-nav-btn prev-btn" aria-label="السابق">
                    <i class="ri-arrow-right-line"></i>
                </button>
                <button class="portfolio-nav-btn next-btn" aria-label="التالي">
                    <i class="ri-arrow-left-line"></i>
                </button>

                <div class="swiper portfolio-swiper">
                    <div class="swiper-wrapper">
                        <% if (projects && projects.length > 0) { %>
                            <% projects.forEach(function(project) { %>
                                <div class="swiper-slide">
                                    <div class="project-card">
                                        <% if (project.image && (project.image.endsWith('.mp4') || project.image.endsWith('.webm'))) { %>
                                            <video src="<%= assetPath(project.image) %>" muted loop playsinline></video>
                                        <% } else if (project.image) { %>
                                            <img src="<%= assetPath(project.image) %>"
                                                 alt="<%= project.title_ar || project.title || '' %>"
                                                 width="1200" height="800" loading="lazy" decoding="async">
                                        <% } else { %>
                                            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                                                 alt="مشروع" width="800" height="600" loading="lazy" decoding="async">
                                        <% } %>
                                        <div class="project-overlay">
                                            <div class="project-info">
                                                <h3><%= project.title_ar || project.title || '' %></h3>
                                                <p><%= project.description_ar || project.description || '' %></p>
                                                <a href="<%= project.externalLink || '/portfolio/' + project.id %>"
                                                   class="project-link"
                                                   <%= project.externalLink ? 'target="_blank" rel="noopener noreferrer"' : '' %>>
                                                    <span>مشاهدة المشروع</span>
                                                    <i class="ri-arrow-left-line"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <% for (var i = 1; i <= 6; i++) { %>
                                <div class="swiper-slide">
                                    <div class="project-card">
                                        <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                                             alt="مشروع إبداعي <%= i %>">
                                        <div class="project-overlay">
                                            <div class="project-info">
                                                <h3>مشروع إبداعي <%= i %></h3>
                                                <p>وصف قصير للمشروع وكيف ساعدنا العميل في تحقيق أهدافه.</p>
                                                <a href="#" class="project-link">
                                                    <span>مشاهدة المشروع</span>
                                                    <i class="ri-arrow-left-line"></i>
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% } %>
                        <% } %>
                    </div>
                    <div class="swiper-pagination"></div>
                </div>
            </div>
        </div>
    </section>

    <!-- ========================= Partners Section ========================== -->
    <section id="partners" class="partners-section">
        <div class="container">
            <div class="partners-header" data-gsap="fade-up">
                <h2 class="partners-title">نفخر بأعمالنا ونعتز أكثر بالشراكات التي أسسناها.</h2>
            </div>
            <div class="partners-grid">
                <% if (partners && partners.length > 0) { %>
                    <% partners.forEach(function(partner) { %>
                        <div class="partner-item" data-gsap="fade-up">
                            <img src="<%= assetPath(partner.logo || '') %>"
                                 alt="<%= partner.name || '' %>"
                                 title="<%= partner.name || '' %>"
                                 loading="lazy" decoding="async" width="200" height="80">
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="partner-item" data-gsap="fade-up">
                        <p style="color:#444; font-size:0.9rem;">لا توجد شركاء مضافون حالياً</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- ========================= Blog Section ========================== -->
    <section id="blog" class="blog-home-section">
        <div class="container">
            <div class="blog-section-inner" data-gsap="fade-up">
                <div class="section-header" style="text-align: center; margin-bottom: 3rem;">
                    <h2 class="section-title" style="font-size: 2.5rem; margin-bottom: 1rem;">آخر المقالات</h2>
                    <p style="color: #888; font-size: 1.1rem;">رؤى وأفكار في عالم التصميم والتقنية</p>
                </div>

                <div class="blog-grid">
                    <% if (posts && posts.length > 0) { %>
                        <% posts.forEach(function(post) { %>
                            <article class="blog-card">
                                <% if (post.image) { %>
                                    <div class="blog-image">
                                        <img src="<%= assetPath(post.image) %>"
                                             alt="<%= post.title_ar || post.title || '' %>"
                                             loading="lazy" decoding="async">
                                    </div>
                                <% } %>
                                <div class="blog-content">
                                    <span class="blog-date"><%= post.date || '' %></span>
                                    <h3><%= post.title_ar || post.title || '' %></h3>
                                    <p class="blog-excerpt"><%= post.excerpt_ar || post.excerpt || '' %></p>
                                    <a href="/blog/<%= post.id %>" class="read-more">
                                        <span>اقرأ المزيد</span>
                                        <i class="ri-arrow-left-line"></i>
                                    </a>
                                </div>
                            </article>
                        <% }); %>
                    <% } else { %>
                        <div style="grid-column: 1/-1; text-align: center; padding: 50px; background: #0a0a0a; border-radius: 20px; border: 1px solid #1a1a1a;">
                            <p style="color: #666;">لا توجد مقالات متوفرة حالياً.</p>
                        </div>
                    <% } %>
                </div>

                <div class="view-all-container">
                    <a href="/blog" class="view-all-btn">عرض كل المقالات</a>
                </div>
            </div>
        </div>
    </section>

    <!-- ========================= Contact Section ========================== -->
    <section id="contact" class="contact-section">
        <div class="marquee-wrapper contact-marquee">
            <div class="marquee-content" aria-hidden="true">
                <h2 class="finale-text">CREATIVE POINT</h2>
                <h2 class="finale-text">CREATIVE POINT</h2>
                <h2 class="finale-text">CREATIVE POINT</h2>
                <h2 class="finale-text">CREATIVE POINT</h2>
            </div>
        </div>
        <div class="container">
            <div class="contact-grid">
                <div class="contact-info" data-gsap="fade-right">
                    <h2 class="contact-title">
                        <%- (seo && seo.contactTitleAr ? seo.contactTitleAr : 'ابدأ رحلة<br>إبداعية جديدة').replace(/\n/g, '<br>') %>
                    </h2>
                    <p class="contact-subtitle">
                        <%= seo && seo.contactSubtitleAr ? seo.contactSubtitleAr : 'نحن هنا لنستمع لأفكارك ونحولها إلى استراتيجية بصرية مؤثرة. اتصل بنا اليوم.' %>
                    </p>

                    <div class="contact-details">
                        <div class="contact-item">
                            <i class="ri-phone-line"></i>
                            <div>
                                <span>اتصل بنا</span>
                                <p dir="ltr"><%= seo && seo.contactPhone ? seo.contactPhone : '+966 56 839 49 45' %></p>
                            </div>
                        </div>
                        <div class="contact-item">
                            <i class="ri-mail-line"></i>
                            <div>
                                <span>البريد الإلكتروني</span>
                                <p><%= seo && seo.contactEmail ? seo.contactEmail : 'info@cpoint-sa.com' %></p>
                            </div>
                        </div>
                        <div class="contact-item">
                            <i class="ri-map-pin-line"></i>
                            <div>
                                <span>الموقع</span>
                                <p><%= seo && seo.contactLocationAr ? seo.contactLocationAr : 'الرياض، المملكة العربية السعودية' %></p>
                            </div>
                        </div>
                    </div>

                    <div class="social-links">
                        <% if (seo && seo.socialInstagram) { %>
                            <a href="<%= seo.socialInstagram %>" target="_blank" rel="noopener noreferrer" aria-label="Instagram"><i class="ri-instagram-line"></i></a>
                        <% } %>
                        <% if (seo && seo.socialTwitter) { %>
                            <a href="<%= seo.socialTwitter %>" target="_blank" rel="noopener noreferrer" aria-label="X / Twitter"><i class="ri-twitter-x-line"></i></a>
                        <% } %>
                        <% if (seo && seo.socialLinkedin) { %>
                            <a href="<%= seo.socialLinkedin %>" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn"><i class="ri-linkedin-box-line"></i></a>
                        <% } %>
                    </div>
                </div>

                <div class="contact-form-wrapper" data-gsap="fade-left">
                    <form action="/contact" method="POST" class="contact-form">
                        <div class="form-group">
                            <input type="text" name="name" placeholder="الاسم الكامل" required autocomplete="name">
                        </div>
                        <div class="form-group">
                            <input type="email" name="email" placeholder="البريد الإلكتروني" required autocomplete="email">
                        </div>
                        <div class="form-group">
                            <input type="tel" name="phone" placeholder="رقم الهاتف" autocomplete="tel">
                        </div>
                        <div class="form-group">
                            <select name="service">
                                <option value="" disabled selected>اختر الخدمة</option>
                                <option value="branding">الهوية البصرية</option>
                                <option value="marketing">التسويق الرقمي</option>
                                <option value="web">تطوير المواقع</option>
                                <option value="other">أخرى</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <textarea name="message" rows="5" placeholder="تفاصيل المشروع" required></textarea>
                        </div>
                        <button type="submit" class="submit-btn" id="contact-submit-btn">
                            <span>إرسال الطلب</span>
                            <i class="ri-send-plane-fill"></i>
                        </button>
                    </form>

                    <div id="contact-success" style="display:none; margin-top:20px; padding:15px; background:#222; border:1px solid #fff; border-radius:10px; color:#fff; text-align:center;" role="alert">
                        <i class="ri-checkbox-circle-line" style="font-size:1.5rem; vertical-align:middle; margin-left:10px;"></i>
                        تم إرسال طلبك بنجاح! سنتواصل معك قريباً.
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

<script>
    (function () {
        var urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('success')) {
            var successEl = document.getElementById('contact-success');
            var formEl    = document.querySelector('.contact-form');
            if (successEl) successEl.style.display = 'block';
            if (formEl)    formEl.style.display    = 'none';
        }
    })();
</script>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script id="slider-config-data" type="application/json">
    <%- JSON.stringify({
        effect:           (seo && seo.sliderEffect)           ? seo.sliderEffect           : "slide",
