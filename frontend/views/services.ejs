<%- include('partials/header') %>

<style>
    /* تنسيقات صفحة الخدمات مطابقة للتصميم المرفق */
    .services-page-wrapper {
        background-color: #000000;
        color: #ffffff;
        padding: 120px 0 60px;
        min-height: 100vh;
        font-family: 'TheSansArabic', sans-serif;
    }
    
    .services-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* أزرار التنقل بين الخدمات */
    .services-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        justify-content: center;
        margin-bottom: 60px;
    }

    .service-tab-btn {
        background: transparent;
        color: #fff;
        border: 1px solid #333;
        padding: 10px 25px;
        border-radius: 30px;
        cursor: pointer;
        font-family: inherit;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .service-tab-btn:hover {
        border-color: #D00000;
    }

    .service-tab-btn.active {
        background: #D00000;
        border-color: #D00000;
        color: #fff;
    }

    /* محتوى الخدمة */
    .service-content {
        display: none;
        animation: fadeIn 0.5s ease;
    }

    .service-content.active {
        display: block;
    }

    /* القسم العلوي (النص والصورة الرئيسية) */
    .service-hero {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 50px;
        margin-bottom: 60px;
    }

    .service-text {
        flex: 1;
    }

    .service-title {
        font-size: 2.5rem;
        font-weight: bold;
        margin-bottom: 15px;
    }

    .service-desc {
        font-size: 1.1rem;
        color: #ccc;
        margin-bottom: 30px;
        line-height: 1.6;
    }

    .service-bullets {
        list-style: none;
        padding: 0;
        margin: 25px 0 10px;
    }

    .service-bullets li {
        position: relative;
        padding: 12px 16px 12px 16px;
        margin-bottom: 10px;
        font-size: 1rem;
        color: #ddd;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 10px;
        line-height: 1.6;
        transition: all 0.3s ease;
    }

    .service-bullets li:hover {
        background: rgba(255, 49, 49, 0.06);
        border-color: rgba(255, 49, 49, 0.2);
        transform: translateX(4px);
    }

    html[dir="rtl"] .service-bullets li {
        padding-right: 40px;
        padding-left: 16px;
    }

    html[dir="ltr"] .service-bullets li {
        padding-right: 16px;
        padding-left: 40px;
    }

    html[dir="rtl"] .service-bullets li:hover {
        transform: translateX(-4px);
    }

    html[dir="ltr"] .service-bullets li:hover {
        transform: translateX(4px);
    }

    .service-bullets li::before {
        content: '';
        position: absolute;
        top: 19px;
        width: 8px;
        height: 8px;
        background-color: #D00000;
        border-radius: 50%;
        box-shadow: 0 0 10px rgba(208, 0, 0, 0.5);
    }

    html[dir="rtl"] .service-bullets li::before {
        right: 18px;
    }

    html[dir="ltr"] .service-bullets li::before {
        left: 18px;
    }

    html[lang="en"] .service-bullets li::before,
    [dir="ltr"] .service-bullets li::before {
        left: 0;
    }

    .service-main-img {
        flex: 1;
        text-align: center;
    }

    .service-main-img img {
        max-width: 100%;
        height: auto;
        border-radius: 10px;
    }

    /* معرض الصور (الشبكة) */
    .service-gallery {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
        margin-bottom: 80px;
    }

    .gallery-item img {
        width: 100%;
        height: 100%;
        min-height: 300px;
        object-fit: cover;
        border-radius: 10px;
    }

    /* قسم التواصل السفلي */
    .cta-section {
        border-top: 1px solid #222;
        padding-top: 50px;
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .cta-text h2 {
        font-size: 2.5rem;
        margin-bottom: 15px;
    }

    .cta-text p {
        color: #aaa;
        font-size: 1.1rem;
    }

    .cta-form {
        flex: 0 0 400px;
    }

    .cta-form input {
        width: 100%;
        background: transparent;
        border: 1px solid #333;
        padding: 15px;
        border-radius: 30px;
        color: #fff;
        margin-bottom: 15px;
        font-family: inherit;
    }

    .cta-form input:focus {
        outline: none;
        border-color: #D00000;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 768px) {
        .service-hero { flex-direction: column-reverse; }
        .service-gallery { grid-template-columns: 1fr; }
        .cta-section { flex-direction: column; gap: 30px; }
        .cta-form { width: 100%; flex: auto; }
    }
</style>

<div class="services-page-wrapper" dir="<%= lang === 'en' ? 'ltr' : 'rtl' %>">
    <div class="services-container">
        
        <!-- أزرار التنقل (تتولد تلقائياً من الإدارة) -->
    <div class="services-nav">
        <% const hasActive = typeof activeService !== 'undefined' && activeService; %>
        <% services.forEach((service, index) => { %>
            <button class="service-tab-btn <%= (!hasActive && index === 0) || (hasActive && activeService.id === service.id) ? 'active' : '' %>" data-index="<%= index %>" onclick="switchService(this.getAttribute('data-index'))">
                <%= lang === 'en' ? service.title_en : service.title_ar %>
            </button>
        <% }) %>
    </div>

    <!-- محتوى الخدمات -->
    <% services.forEach((service, index) => { %>
        <div class="service-content <%= (!hasActive && index === 0) || (hasActive && activeService.id === service.id) ? 'active' : '' %>" id="service-<%= index %>">
                
                <!-- القسم العلوي -->
                <div class="service-hero">
                    <div class="service-text">
                        <h1 class="service-title"><%= lang === 'en' ? service.title_en : service.title_ar %></h1>
                        <p class="service-desc"><%= lang === 'en' ? service.description_en : service.description_ar %></p>
                        
                        <ul class="service-bullets">
                            <% 
                                let rawBullets = lang === 'en' ? service.bullet_points_en : service.bullet_points_ar;
                                if(rawBullets) {
                                    let bullets = rawBullets.split('\n').filter(b => b.trim() !== '');
                                    bullets.forEach(bullet => { 
                            %>
                                <li><%= bullet %></li>
                            <% 
                                    });
                                } 
                            %>
                        </ul>
                    </div>
                    
                    <div class="service-main-img">
                        <% if(service.image) { %>
                            <img src="<%= assetPath(service.image) %>" alt="<%= lang === 'en' ? service.title_en : service.title_ar %>">
                        <% } %>
                    </div>
                </div>

                <!-- معرض الصور -->
                <% if(service.gallery_images && service.gallery_images.length > 0) { %>
                    <div class="service-gallery">
                        <% service.gallery_images.forEach(img => { %>
                            <% if(img) { %>
                                <div class="gallery-item">
                                    <img src="<%= assetPath(img) %>" alt="Gallery Image">
                                </div>
                            <% } %>
                        <% }) %>
                    </div>
                <% } %>
                
            </div>
        <% }) %>

        <!-- قسم التواصل السفلي -->
        <div class="cta-section">
            <div class="cta-text">
                <h2><%= lang === 'en' ? 'Let\'s start a new' : 'لنبدأ رحلة' %><br><span style="color: #fff;"><%= lang === 'en' ? 'Creative Journey' : 'إبداعية جديدة' %></span></h2>
                <p><%= lang === 'en' ? 'We are here to hear your ideas and turn them into an impactful visual strategy. Contact us today.' : 'نحن هنا لنسمع أفكارك ونحولها إلى استراتيجية بصرية مؤثرة. تواصل معنا اليوم.' %></p>
            </div>
            
            <div class="cta-form">
                <form action="/contact" method="POST">
                    <input type="text" name="name" placeholder="<%= lang === 'en' ? 'Full Name' : 'الاسم كاملاً' %>" required>
                    <input type="email" name="email" placeholder="<%= lang === 'en' ? 'Email Address' : 'البريد الإلكتروني' %>" required>
                    <input type="text" name="phone" placeholder="<%= lang === 'en' ? 'Phone Number' : 'رقم الجوال' %>">
                    <input type="text" name="service" placeholder="<%= lang === 'en' ? 'Required Service' : 'نوع الخدمة المطلوبة' %>">
                    <button type="submit" class="service-tab-btn active" style="width: 100%; margin-top: 10px;">
                        <%= lang === 'en' ? 'Send' : 'أخبرنا بما تريد' %>
                    </button>
                </form>
            </div>
        </div>

    </div>
</div>

<script>
    function switchService(index) {
        // إزالة الكلاس active من كل الأزرار والمحتوى
        var buttons = document.querySelectorAll('.service-tab-btn');
        var contents = document.querySelectorAll('.service-content');
        
        for(var i = 0; i < buttons.length; i++) {
            buttons[i].classList.remove('active');
        }
        for(var j = 0; j < contents.length; j++) {
            contents[j].classList.remove('active');
        }
        
        // إضافة الكلاس active للزر والمحتوى المختار
        var selectedBtn = document.querySelector('.service-tab-btn[data-index="' + index + '"]');
        var selectedContent = document.getElementById('service-' + index);
        
        if(selectedBtn) selectedBtn.classList.add('active');
        if(selectedContent) selectedContent.classList.add('active');
    }
</script>

<%- include('partials/footer') %>
