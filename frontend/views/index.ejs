<%- include('partials/header') %>

<!-- Hero Section -->
<div class="hero-section">
    <div class="hero-content">
        <h1 class="slogan">
            <span class="en">Every Creativity Start's With a <span class="highlight-point">Point</span></span>
            <span class="ar">كل إبداع يبدأ <span class="highlight-point">بنقطة</span></span>
        </h1>
        <div class="hero-description">
            <div class="ar">
                <p><%= globalSeo && globalSeo.homeDescription ? globalSeo.homeDescription : 'وصف افتراضي للشركة...' %></p>
            </div>
        </div> 
    </div>
</div>

<!-- Contents / Navigation -->
<section class="contents-nav">
    <h2 class="section-header">
        <span class="ar">المحتويات</span>
        <span class="en">Contents</span>
    </h2>
    <div class="nav-grid">
        <a href="#journey" class="nav-item"><span class="ar">رحلتها</span><span class="en">Journey</span></a>
        <a href="/philosophy" class="nav-item"><span class="ar">فلسفتها</span><span class="en">Philosophy</span></a>
        <a href="/services" class="nav-item"><span class="ar">خدماتها</span><span class="en">Services</span></a>
        <a href="#portfolio" class="nav-item"><span class="ar">أعمالنا</span><span class="en">Portfolio</span></a>
        <a href="#partners" class="nav-item"><span class="ar">شركاؤها</span><span class="en">Partners</span></a>
    </div>
</section>

<!-- Services Section (عرض الخدمات ديناميكياً) -->
<section id="services" class="content-section">
    <div class="section-title-wrapper">
        <h2><span class="ar">خدماتنا</span><span class="en">Our Services</span></h2>
    </div>
    <div class="services-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; padding: 20px;">
        <% if (services && services.length > 0) { %>
            <% services.forEach(service => { %>
                <div class="service-card" style="border: 1px solid #eee; padding: 15px; border-radius: 8px;">
                    <img src="<%= service.image %>" alt="<%= service.title_ar %>" style="width: 100%; height: 200px; object-fit: cover;">
                    <h3><%= lang === 'ar' ? service.title_ar : service.title_en %></h3>
                    <p><%= lang === 'ar' ? service.description_ar : service.description_en %></p>
                </div>
            <% }) %>
        <% } else { %>
            <p class="text-center">لا توجد خدمات حالياً</p>
        <% } %>
    </div>
</section>

<!-- Portfolio Section (عرض الأعمال ديناميكياً) -->
<section id="portfolio" class="content-section">
    <div class="section-title-wrapper">
        <h2><span class="ar">آخر الأعمال</span><span class="en">Latest Works</span></h2>
    </div>
    <div class="portfolio-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 15px; padding: 20px;">
        <% if (projects && projects.length > 0) { %>
            <% projects.forEach(project => { %>
                <a href="/portfolio/<%= project.id %>" class="portfolio-item">
                    <img src="<%= project.main_image %>" alt="<%= project.title_ar %>" style="width: 100%; border-radius: 10px;">
                    <h4><%= lang === 'ar' ? project.title_ar : project.title_en %></h4>
                </a>
            <% }) %>
        <% } %>
    </div>
</section>

<!-- Partners Section (تحديث ليعمل ديناميكياً) -->
<section id="partners" class="content-section partners-section">
    <div class="section-title-wrapper">
        <h2><span class="ar">شركاؤها</span><span class="en">Partners</span></h2>
    </div>
    <div class="partners-grid">
        <% if (partners && partners.length > 0) { %>
            <% partners.forEach(partner => { %>
                <div class="partner-item">
                    <% if (partner.logo) { %>
                        <img src="<%= partner.logo %>" alt="<%= partner.name_ar %>" style="max-height: 60px;">
                    <% } else { %>
                        <span><%= lang === 'ar' ? partner.name_ar : partner.name_en %></span>
                    <% } %>
                </div>
            <% }) %>
        <% } else { %>
            <!-- بيانات احتياطية في حال كانت القاعدة فارغة -->
            <div class="partner-item">Partner 1</div>
            <div class="partner-item">Partner 2</div>
        <% } %>
    </div>
</section>

<!-- Blog Section (اختياري: عرض المقالات) -->
<% if (posts && posts.length > 0) { %>
<section id="blog" class="content-section">
    <div class="section-title-wrapper">
        <h2><span class="ar">المدونة</span><span class="en">Blog</span></h2>
    </div>
    <div class="blog-grid" style="display: flex; gap: 20px; overflow-x: auto; padding: 20px;">
        <% posts.forEach(post => { %>
            <div class="post-card" style="min-width: 250px;">
                <img src="<%= post.thumbnail %>" style="width: 100%;">
                <h5><%= post.title %></h5>
                <a href="/blog/<%= post.id %>">اقرأ المزيد</a>
            </div>
        <% }) %>
    </div>
</section>
<% } %>

<!-- Contact Section -->
<section class="contact-footer">
    <div class="contact-content">
        <h2><span class="ar">لم ينتهي الإبداع</span><span class="en">Creativity has not ended</span></h2>
        <form action="/contact" method="POST" style="max-width: 500px; margin: 0 auto; padding: 20px;">
            <input type="text" name="name" placeholder="الاسم" required style="width:100%; margin-bottom:10px;">
            <input type="email" name="email" placeholder="البريد" required style="width:100%; margin-bottom:10px;">
            <textarea name="message" placeholder="رسالتك" style="width:100%; margin-bottom:10px;"></textarea>
            <button type="submit" class="contact-btn">إرسال</button>
        </form>
    </div>
</section>

<%- include('partials/footer') %>