<% const isEn = true; %>
<%- include('partials/header', { isEn: isEn }) %>

<link rel="preload" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
</noscript>

<style>
    :root {
        --service-overlay-opacity: <%= (globalSeo && globalSeo.serviceOverlayOpacity !== undefined) ? globalSeo.serviceOverlayOpacity : 0.8 %>;
        --service-image-brightness: <%= (globalSeo && globalSeo.serviceImageBrightness !== undefined) ? globalSeo.serviceImageBrightness : 0.5 %>;
        --slider-height: <%= (globalSeo && globalSeo.sliderHeight) ? globalSeo.sliderHeight : '500px' %>;
        --hero-bg: #030303;
        --hero-accent: #ff3131;
        --hero-text: #ffffff;
        --hero-muted: rgba(255, 255, 255, 0.7);
        --hero-font-main: 'TheSansArabic', sans-serif;
    }

    /* ================= Hero Section ================= */
    .hero-modern-section {
        position: relative;
        min-height: 100vh;
        width: 100%;
        background-color: var(--hero-bg);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        overflow: hidden;
        color: var(--hero-text);
        padding: 120px 0 80px;
    }

    .hero-modern-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(255, 49, 49, 0.05) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-container {
        position: relative;
        z-index: 5;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
    }

    .hero-content {
        max-width: 800px;
    }

    .hero-eyebrow {
        color: var(--hero-accent);
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 24px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .hero-title {
        font-size: clamp(2.5rem, 5vw, 4.5rem);
        line-height: 1.1;
        font-weight: 800;
        margin-bottom: 30px;
        color: #fff;
    }

    .hero-description {
        font-size: clamp(1.1rem, 2vw, 1.3rem);
        line-height: 1.6;
        color: var(--hero-muted);
        margin-bottom: 40px;
        max-width: 650px;
    }

    .btn-hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 15px;
        background-color: var(--hero-accent);
        color: #fff;
        padding: 16px 40px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 1.1rem;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 30px rgba(255, 49, 49, 0.3);
    }

    .btn-hero-pill i {
        font-size: 1.4rem;
        transition: transform 0.3s ease;
    }

    .btn-hero-pill:hover {
        transform: translateY(-5px);
        background-color: #e62c2c;
        box-shadow: 0 15px 40px rgba(255, 49, 49, 0.4);
    }

    .btn-hero-pill:hover i {
        transform: translateX(5px);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0.4), rgba(0,0,0,0.8));
        z-index: 2;
    }

    .hero-scroll-indicator {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        opacity: 0.8;
    }

    .hero-scroll-indicator span {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--hero-muted);
    }

    .mouse {
        width: 26px;
        height: 42px;
        border: 2px solid var(--hero-muted);
        border-radius: 20px;
        position: relative;
    }

    .wheel {
        width: 2px;
        height: 6px;
        background-color: var(--hero-accent);
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 2px;
        animation: scrollWheel 2s infinite;
    }

    @keyframes scrollWheel {
        0% { transform: translate(-50%, 0); opacity: 1; }
        100% { transform: translate(-50%, 15px); opacity: 0; }
    }

    .fade-in {
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 0.8s ease forwards;
    }

    .hero-title.fade-in { animation-delay: 0.2s; }
    .hero-description.fade-in { animation-delay: 0.4s; }
    .hero-actions.fade-in { animation-delay: 0.6s; }

    @keyframes fadeInUp {
        to { opacity: 1; transform: translateY(0); }
    }

    @media (max-width: 991px) {
        .hero-title { font-size: 3.5rem; }
        .hero-container { padding: 0 30px; }
    }

    @media (max-width: 768px) {
        .hero-modern-section { padding-top: 100px; text-align: center; }
        .hero-content { margin: 0 auto; }
        .hero-title { font-size: 2.8rem; }
        .hero-description { margin-left: auto; margin-right: auto; }
        .hero-actions { justify-content: center; }
    }

    @media (max-width: 480px) {
        .hero-title { font-size: 2.2rem; }
        .hero-eyebrow { font-size: 1rem; }
        .btn-hero-pill { padding: 14px 30px; font-size: 1rem; }
    }

    /* ================= Achievements / Stats Section ================= */
    .achievements-section {
        background-color: #050505;
        padding: 80px 0;
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .achievements-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-around;
        gap: 40px;
        text-align: center;
    }
    .achievement-card {
        flex: 1;
        min-width: 200px;
    }
    .achievement-number {
        font-size: 3.5rem;
        font-weight: 900;
        color: var(--hero-accent);
        margin-bottom: 10px;
        font-family: Arial, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }
    .achievement-label {
        font-size: 1.1rem;
        color: #a0a0a0;
        font-weight: bold;
    }

    /* ================= Services Section (LTR) ================= */
    .cpoint-services-section {
        background-color: #000000;
        color: #ffffff;
        padding: 120px 0;
        position: relative;
        overflow: hidden;
    }
    .cpoint-services-header {
        text-align: center;
        margin-bottom: 80px;
        position: relative;
    }
    .cpoint-services-header h2 {
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        font-weight: 900;
        margin-bottom: 20px;
        color: #ffffff;
    }
    .cpoint-services-header p {
        font-size: clamp(1rem, 1.5vw, 1.2rem);
        color: #a0a0a0;
        line-height: 1.6;
        max-width: 700px;
        margin: 0 auto;
    }
    .header-red-dot {
        position: absolute;
        top: -20px;
        left: 15%;
        width: 14px;
        height: 14px;
        background-color: #ff3131;
        border-radius: 50%;
    }
    .cpoint-services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 60px 40px;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
    }
    .cpoint-service-item:nth-child(2) { margin-top: 100px; }
    .cpoint-service-item:nth-child(5) { margin-top: -60px; }
    .cpoint-service-item:nth-child(4) { margin-top: -40px; }
    .cpoint-service-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 30px;
    }
    .cpoint-service-item::after {
        content: '';
        position: absolute;
        right: -20px;
        top: 20%;
        height: 60%;
        width: 1px;
        background: rgba(255, 255, 255, 0.05);
    }
    .cpoint-service-item:nth-child(3n)::after { display: none; }
    .cpoint-svc-num {
        position: absolute;
        top: 0;
        left: 0;
        font-size: 1.2rem;
        font-weight: 700;
        color: #ffffff;
        font-family: sans-serif;
    }
    .cpoint-svc-img {
        width: 100%;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        margin-top: 30px;
    }
    .cpoint-svc-img img {
        max-width: 90%;
        max-height: 100%;
        object-fit: contain;
        background: transparent;
        transition: transform 0.4s ease;
    }
    .cpoint-service-item:hover .cpoint-svc-img img { transform: scale(1.05); }
    .cpoint-svc-content {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        text-align: left;
    }
    .cpoint-svc-title-row {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
        margin-bottom: 5px;
        width: 100%;
    }
    .cpoint-svc-title-row h3 {
        font-size: 1.3rem;
        font-weight: 800;
        color: #ffffff;
        margin: 0;
    }
    .item-red-dot {
        width: 8px;
        height: 8px;
        background-color: #ff3131;
        border-radius: 50%;
        flex-shrink: 0;
    }
    .cpoint-svc-content p {
        font-size: 0.85rem;
        color: #888888;
        margin: 0;
        margin-left: 18px;
        font-family: Arial, sans-serif;
    }
    @media (max-width: 991px) {
        .cpoint-services-grid { grid-template-columns: repeat(2, 1fr); gap: 40px; }
        .cpoint-service-item:nth-child(n) { margin-top: 0 !important; }
        .cpoint-service-item::after { display: none; }
        .header-red-dot { display: none; }
    }
    @media (max-width: 768px) {
        .cpoint-services-grid { grid-template-columns: 1fr; }
        .cpoint-svc-img { height: 180px; }
    }

    /* ================= Portfolio Grid Section ================= */
    .cpoint-portfolio-section {
        background-color: #ffffff;
        padding: 100px 0 0 0;
    }
    .cpoint-portfolio-header {
        text-align: center;
        margin-bottom: 60px;
        padding: 0 20px;
    }
    .cpoint-portfolio-header h2 {
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        font-weight: 900;
        color: #000000;
        margin-bottom: 15px;
    }
    .cpoint-portfolio-header p {
        font-size: 1.1rem;
        color: #666666;
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
    }
    .cpoint-portfolio-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: 300px;
        gap: 0;
        width: 100%;
    }
    .cpoint-project-item {
        position: relative;
        display: block;
        overflow: hidden;
        text-decoration: none;
    }
    .cpoint-project-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
        display: block;
    }
    .cpoint-project-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
        display: flex;
        align-items: flex-end;
        padding: 30px;
        opacity: 0;
        transition: opacity 0.4s ease;
    }
    .cpoint-project-overlay h3 {
        color: #fff;
        font-size: 1.5rem;
        font-weight: bold;
        transform: translateY(20px);
        transition: transform 0.4s ease;
        margin: 0;
    }
    .cpoint-project-item:hover img { transform: scale(1.08); }
    .cpoint-project-item:hover .cpoint-project-overlay { opacity: 1; }
    .cpoint-project-item:hover .cpoint-project-overlay h3 { transform: translateY(0); }

    .cpoint-project-item:nth-child(6n + 1) { grid-column: span 1; grid-row: span 1; }
    .cpoint-project-item:nth-child(6n + 2) { grid-column: span 2; grid-row: span 2; }
    .cpoint-project-item:nth-child(6n + 3) { grid-column: span 1; grid-row: span 1; }
    .cpoint-project-item:nth-child(6n + 4) { grid-column: span 1; grid-row: span 1; }
    .cpoint-project-item:nth-child(6n + 5) { grid-column: span 1; grid-row: span 1; }
    .cpoint-project-item:nth-child(6n + 6) { grid-column: span 4; grid-row: span 1; }

    @media (max-width: 1024px) {
        .cpoint-portfolio-grid { grid-auto-rows: 250px; }
    }
    @media (max-width: 768px) {
        .cpoint-portfolio-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px; }
        .cpoint-project-item:nth-child(n) { grid-column: span 1; grid-row: span 1; }
        .cpoint-project-item:nth-child(6n + 6) { grid-column: span 2; }
    }

    /* ================= Blog & Contact Section ================= */
    .blog-home-section { padding: 100px 0; background: #fafafa; }
    .contact-section { padding: 100px 0; background: #111; color: #fff; position: relative; }
</style>

<main>

    <!-- ========================= Hero Section ========================== -->
    <%
        var seo = globalSeo;
        var heroBgStyle = (seo && seo.heroBackgroundImage) ? `style="background-image: url('${assetPath(seo.heroBackgroundImage)}');"` : "";
    %>
    <section class="hero-modern-section" <%- heroBgStyle %>>
        <div class="hero-overlay"></div>

        <div class="container hero-container">
            <div class="hero-content">
                <p class="hero-eyebrow fade-in">
                    <%= seo && seo.heroSmallTitleEn ? seo.heroSmallTitleEn : 'Creativity starts with a point' %>
                </p>
                <h1 class="hero-title fade-in">
                    <%- (seo && seo.heroMainTitleEn ? seo.heroMainTitleEn : 'A Full-Service Creative &<br>Marketing Agency').replace(/\n/g, '<br>') %>
                </h1>
                <p class="hero-description fade-in">
                    <%= seo && seo.heroDescriptionEn ? seo.heroDescriptionEn : 'Built around one clear idea before any execution begins. We believe that clarity of vision is the foundation of every successful project.' %>
                </p>
                <div class="hero-actions fade-in">
                    <a href="#services" class="btn-hero-pill">
                        <%= seo && seo.heroBtnTextEn ? seo.heroBtnTextEn : 'Explore Our Services' %>
                        <i class="ri-arrow-right-line"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="hero-scroll-indicator">
            <div class="mouse"><div class="wheel"></div></div>
            <span>Scroll</span>
        </div>
    </section>

    <!-- ========================= Stats / Achievements Section ========================== -->
    <% if (typeof stats !== 'undefined' && stats && stats.length) { %>
    <section class="achievements-section">
        <div class="container">
            <div class="achievements-grid" data-gsap="fade-up">
                <% stats.forEach(function(stat) { %>
                    <div class="achievement-card">
                        <div class="achievement-number">
                            <span class="stat-number" data-target="<%= stat.value %>"><%= stat.value %></span>
                            <% if (stat.suffix_en) { %>
                                <span class="stat-suffix"><%= stat.suffix_en %></span>
                            <% } %>
                        </div>
                        <p class="achievement-label"><%= stat.label_en %></p>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- ========================= Partners Section ========================== -->
    <section id="partners" class="partners-section" style="padding: 60px 0; background:#f9f9f9;">
        <div class="container">
            <div class="partners-header" data-gsap="fade-up" style="text-align:center; margin-bottom:40px;">
                <h2 class="partners-title" style="font-size:1.8rem; font-weight:bold; color:#000;">We take pride in our work and are even more proud of our partnerships.</h2>
            </div>
            <div class="partners-grid" style="display:flex; justify-content:center; gap:30px; flex-wrap:wrap; align-items:center;">
                <% if (partners && partners.length > 0) { %>
                    <% partners.forEach(function(partner) { %>
                        <div class="partner-item" data-gsap="fade-up">
                            <img src="<%= assetPath(partner.logo || '') %>"
                                 alt="<%= partner.name || '' %>"
                                 title="<%= partner.name || '' %>"
                                 loading="lazy" decoding="async" width="150"
                                 style="filter:grayscale(100%); opacity:0.7; transition:all 0.3s;">
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="partner-item" data-gsap="fade-up">
                        <p style="color:#444; font-size:0.9rem;">No partners added yet.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- ========================= Services Section ========================== -->
    <section id="services" class="cpoint-services-section">
        <div class="container" style="max-width: 1400px; padding: 0 40px;">
            <div class="cpoint-services-header" data-gsap="fade-up">
                <div class="header-red-dot"></div>
                <h2>Our Services</h2>
                <p>
                    Integrated solutions starting from a clear point.<br>
                    Every service is built around a single strategic decision, transforming into a visual experience<br>
                    and tangible applications that stack together to create a cohesive creative system.
                </p>
            </div>

            <div class="cpoint-services-grid">
                <% var servicesList = (typeof services !== 'undefined' && services) ? services : []; %>
                <% if (servicesList.length) { %>
                    <% servicesList.forEach(function(service, index) { %>
                        <div class="cpoint-service-item" data-gsap="fade-up" data-delay="<%= index * 0.1 %>">
                            <span class="cpoint-svc-num"><%= (index + 1).toString().padStart(2, '0') %></span>
                            <div class="cpoint-svc-img">
                                <% if (service.image) { %>
                                    <img src="<%= assetPath(service.image) %>" alt="<%= service.title_en || '' %>" loading="lazy">
                                <% } else { %>
                                    <div style="width:100px; height:100px; background:rgba(255,255,255,0.1); border-radius:10px;"></div>
                                <% } %>
                            </div>
                            <div class="cpoint-svc-content">
                                <div class="cpoint-svc-title-row">
                                    <div class="item-red-dot"></div>
                                    <h3><%= service.title_en || service.title_ar || 'Service Title' %></h3>
                                </div>
                                <p><%= service.tag1_en || service.description_en || 'Service Description' %></p>
                            </div>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="grid-column: 1/-1; text-align: center; padding: 50px; color: #888;">
                        <p>No services added yet. Please add them from the dashboard.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- ========================= Portfolio Section ========================== -->
    <section id="portfolio" class="cpoint-portfolio-section">
        <div class="cpoint-portfolio-header" data-gsap="fade-up">
            <h2>Our Latest Projects</h2>
            <p>Turning ideas into tangible reality — every creation starts with a point.<br>Explore all our work.</p>
        </div>

        <div class="cpoint-portfolio-grid">
            <% if (projects && projects.length > 0) { %>
                <% projects.forEach(function(project) { %>
                    <a href="<%= project.externalLink || '/portfolio/' + project.id %>"
                       class="cpoint-project-item"
                       <%= project.externalLink ? 'target="_blank" rel="noopener noreferrer"' : '' %>>

                        <% if (project.image && (project.image.endsWith('.mp4') || project.image.endsWith('.webm'))) { %>
                            <video src="<%= assetPath(project.image) %>" muted loop autoplay playsinline style="width:100%; height:100%; object-fit:cover;"></video>
                        <% } else if (project.image) { %>
                            <img src="<%= assetPath(project.image) %>"
                                 alt="<%= project.title_en || '' %>"
                                 loading="lazy" decoding="async">
                        <% } else { %>
                            <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80"
                                 alt="Project" loading="lazy">
                        <% } %>

                        <div class="cpoint-project-overlay">
                            <h3><%= project.title_en || 'Creative Project' %></h3>
                        </div>
                    </a>
                <% }); %>
            <% } else { %>
                <a href="#" class="cpoint-project-item"><img src="https://images.unsplash.com/photo-1513364776144-60967b0f800f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="1"><div class="cpoint-project-overlay"><h3>Creative Design</h3></div></a>
                <a href="#" class="cpoint-project-item"><img src="https://images.unsplash.com/photo-1600132806370-bf17e65e942f?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="2"><div class="cpoint-project-overlay"><h3>Visual Identity</h3></div></a>
                <a href="#" class="cpoint-project-item"><img src="https://images.unsplash.com/photo-1562602833-0f4ab2fc46e3?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="3"><div class="cpoint-project-overlay"><h3>Printing & Production</h3></div></a>
                <a href="#" class="cpoint-project-item"><img src="https://images.unsplash.com/photo-1557672172-298e090bd0f1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="4"><div class="cpoint-project-overlay"><h3>Photography</h3></div></a>
                <a href="#" class="cpoint-project-item"><img src="https://images.unsplash.com/photo-1542744173-8e7e53415bb0?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="5"><div class="cpoint-project-overlay"><h3>Web Development</h3></div></a>
                <a href="#" class="cpoint-project-item"><img src="https://images.unsplash.com/photo-1558655146-d09347e92766?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" alt="6"><div class="cpoint-project-overlay"><h3>Strategic Planning</h3></div></a>
            <% } %>
        </div>
    </section>

    <!-- ========================= Blog Section ========================== -->
    <section id="blog" class="blog-home-section">
        <div class="container">
            <div class="blog-section-inner" data-gsap="fade-up">
                <div class="section-header" style="text-align: center; margin-bottom: 3rem;">
                    <h2 class="section-title" style="font-size: 2.5rem; margin-bottom: 1rem; color:#000;">Latest Articles</h2>
                    <p style="color: #888; font-size: 1.1rem;">Insights and ideas in the world of design and technology</p>
                </div>

                <div class="blog-grid" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:30px;">
                    <% if (posts && posts.length > 0) { %>
                        <% posts.forEach(function(post) { %>
                            <article class="blog-card" style="background:#fff; border-radius:15px; overflow:hidden; box-shadow:0 10px 30px rgba(0,0,0,0.05);">
                                <% if (post.image) { %>
                                    <div class="blog-image" style="height:200px; overflow:hidden;">
                                        <img src="<%= assetPath(post.image) %>"
                                             alt="<%= post.title_en || post.title || '' %>"
                                             loading="lazy" decoding="async"
                                             style="width:100%; height:100%; object-fit:cover;">
                                    </div>
                                <% } %>
                                <div class="blog-content" style="padding:25px;">
                                    <span class="blog-date" style="color:#ff3131; font-size:0.85rem;"><%= post.date || '' %></span>
                                    <h3 style="margin:10px 0; font-size:1.3rem; color:#000;"><%= post.title_en || post.title || '' %></h3>
                                    <p class="blog-excerpt" style="color:#666; font-size:0.9rem; margin-bottom:20px;"><%= post.excerpt_en || post.excerpt || '' %></p>
                                    <a href="/blog/<%= post.id %>" class="read-more"
                                       style="color:#000; font-weight:bold; text-decoration:none; display:inline-flex; align-items:center; gap:5px;">
                                        <span>Read More</span>
                                        <i class="ri-arrow-right-line"></i>
                                    </a>
                                </div>
                            </article>
                        <% }); %>
                    <% } else { %>
                        <div style="grid-column: 1/-1; text-align: center; padding: 50px; background: #fff; border-radius: 20px; border: 1px solid #eee;">
                            <p style="color: #666;">No articles available at the moment.</p>
                        </div>
                    <% } %>
                </div>

                <div class="view-all-container" style="text-align:center; margin-top:40px;">
                    <a href="/blog" class="view-all-btn"
                       style="background:#000; color:#fff; padding:12px 30px; border-radius:30px; text-decoration:none; font-weight:bold;">
                        View All Articles
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- ========================= Contact Section ========================== -->
    <section id="contact" class="contact-section">
        <div class="container">
            <div class="contact-layout">
                <div class="contact-form-panel" data-gsap="fade-left">
                    <form action="/contact" method="POST" class="contact-form">
                        <input type="text" class="contact-field" name="name" placeholder="Full Name" required autocomplete="name">
                        <input type="email" class="contact-field" name="email" placeholder="Email Address" required autocomplete="email">
                        <input type="tel" class="contact-field" name="phone" placeholder="Phone Number" autocomplete="tel">
                        <input type="text" class="contact-field" name="service" placeholder="Required Service">
                        <textarea class="contact-field" name="message" rows="4" placeholder="Tell us what you need" required></textarea>
                        <button type="submit" class="contact-submit-btn" id="contact-submit-btn">
                            <span>Send Request</span>
                            <i class="ri-send-plane-fill"></i>
                        </button>
                    </form>

                    <div id="contact-success" class="contact-success-box" style="display:none;" role="alert">
                        <i class="ri-checkbox-circle-line" style="font-size:1.2rem; vertical-align:middle; margin-right:8px;"></i>
                        Your request has been sent successfully! We will contact you soon.
                    </div>
                </div>

                <div class="contact-info-panel" data-gsap="fade-right">
                    <h2 class="contact-title-custom">
                        <%- (seo && seo.contactTitleEn ? seo.contactTitleEn : 'Let’s Start a New<br>Creative Journey').replace(/\n/g, '<br>') %>
                    </h2>
                    <p class="contact-subtitle-custom">
                        <%= seo && seo.contactSubtitleEn ? seo.contactSubtitleEn : 'We listen to your ideas and transform them into an impactful visual strategy. Contact us today.' %>
                    </p>

                    <div class="contact-meta-list">
                        <div class="contact-meta-item">
                            <i class="ri-phone-line contact-meta-icon"></i>
                            <div>
                                <p class="contact-meta-label">Call Us</p>
                                <p class="contact-meta-value" dir="ltr"><%= seo && seo.contactPhone ? seo.contactPhone : '+966 56 839 49 45' %></p>
                            </div>
                        </div>
                        <div class="contact-meta-item">
                            <i class="ri-mail-line contact-meta-icon"></i>
                            <div>
                                <p class="contact-meta-label">Email</p>
                                <p class="contact-meta-value"><%= seo && seo.contactEmail ? seo.contactEmail : 'info@cpoint-sa.com' %></p>
                            </div>
                        </div>
                        <div class="contact-meta-item">
                            <i class="ri-map-pin-line contact-meta-icon"></i>
                            <div>
                                <p class="contact-meta-label">Location</p>
                                <p class="contact-meta-value"><%= seo && seo.contactLocationEn ? seo.contactLocationEn : 'Riyadh, Saudi Arabia' %></p>
                            </div>
                        </div>
                    </div>

                    <div class="contact-social-list">
                        <% if (seo && seo.socialLinkedin) { %>
                            <a href="<%= seo.socialLinkedin %>" target="_blank" rel="noopener noreferrer" class="contact-social-link"><i class="ri-linkedin-box-line"></i></a>
                        <% } %>
                        <% if (seo && seo.socialTwitter) { %>
                            <a href="<%= seo.socialTwitter %>" target="_blank" rel="noopener noreferrer" class="contact-social-link"><i class="ri-twitter-x-line"></i></a>
                        <% } %>
                        <% if (seo && seo.socialInstagram) { %>
                            <a href="<%= seo.socialInstagram %>" target="_blank" rel="noopener noreferrer" class="contact-social-link"><i class="ri-instagram-line"></i></a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </section>

</main>

<script>
    (function () {
        var urlParams = new URLSearchParams(window.location.search);
        if (urlParams.has('success')) {
            var successEl = document.getElementById('contact-success');
            var formEl    = document.querySelector('.contact-form');
            if (successEl) successEl.style.display = 'block';
            if (formEl)    formEl.style.display    = 'none';
        }
    })();
</script>

<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

<script id="slider-config-data" type="application/json">
    <%- JSON.stringify({
        effect:           (seo && seo.sliderEffect)           ? seo.sliderEffect           : "slide",
        autoplay:         (seo && seo.sliderAutoplay)         ? true                       : false,
        autoplayDelay:    (seo && seo.sliderAutoplayDelay)    ? seo.sliderAutoplayDelay    : 3000,
        slidesPerView:    (seo && seo.sliderSlidesPerView)    ? seo.sliderSlidesPerView    : 3,
        spaceBetween:     (seo && seo.sliderSpaceBetween)     ? seo.sliderSpaceBetween     : 30
    }) %>
</script>

<%- include('partials/footer', { isEn: isEn }) %>
