<% const isEn = true; %>
<%- include('partials/header', { isEn: isEn }) %>

<link rel="preload" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
</noscript>

<style>
    :root {
        --service-overlay-opacity: <%= (globalSeo && globalSeo.serviceOverlayOpacity !== undefined) ? globalSeo.serviceOverlayOpacity : 0.8 %>;
        --service-image-brightness: <%= (globalSeo && globalSeo.serviceImageBrightness !== undefined) ? globalSeo.serviceImageBrightness : 0.5 %>;
        --slider-height: <%= (globalSeo && globalSeo.sliderHeight) ? globalSeo.sliderHeight : '500px' %>;
        --hero-bg: #030303;
        --hero-accent: #ff3131;
        --hero-text: #ffffff;
        --hero-muted: rgba(255, 255, 255, 0.7);
        --hero-font-main: 'TheSansArabic', sans-serif;
    }

    /* ================= Hero Section ================= */
    .hero-modern-section {
        position: relative;
        min-height: 100vh;
        width: 100%;
        background-color: var(--hero-bg);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        display: flex;
        align-items: center;
        overflow: hidden;
        color: var(--hero-text);
        padding: 120px 0 80px;
    }
    
    .hero-modern-section::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at center, rgba(255, 49, 49, 0.05) 0%, transparent 70%);
        pointer-events: none;
    }
    
    .hero-container {
        position: relative;
        z-index: 5;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
    }
    
    .hero-content {
        max-width: 800px;
    }
    
    .hero-eyebrow {
        color: var(--hero-accent);
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 24px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }
    
    .hero-title {
        font-size: clamp(2.5rem, 5vw, 4.5rem);
        line-height: 1.1;
        font-weight: 800;
        margin-bottom: 30px;
        color: #fff;
    }
    
    .hero-description {
        font-size: clamp(1.1rem, 2vw, 1.3rem);
        line-height: 1.6;
        color: var(--hero-muted);
        margin-bottom: 40px;
        max-width: 650px;
    }
    
    .btn-hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 15px;
        background-color: var(--hero-accent);
        color: #fff;
        padding: 16px 40px;
        border-radius: 100px;
        font-weight: 700;
        font-size: 1.1rem;
        text-decoration: none;
        transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 10px 30px rgba(255, 49, 49, 0.3);
    }
    
    .btn-hero-pill i {
        font-size: 1.4rem;
        transition: transform 0.3s ease;
    }
    
    .btn-hero-pill:hover {
        transform: translateY(-5px);
        background-color: #e62c2c;
        box-shadow: 0 15px 40px rgba(255, 49, 49, 0.4);
    }
    
    .btn-hero-pill:hover i {
        transform: translateX(5px);
    }
    
    .hero-video-bg {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        z-index: 1;
    }
    
    .hero-video-el {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.7), rgba(0,0,0,0.4), rgba(0,0,0,0.8));
        z-index: 2;
    }
    
    .hero-scroll-indicator {
        position: absolute;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 10;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 10px;
        opacity: 0.8;
    }
    
    .hero-scroll-indicator span {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--hero-muted);
    }
    
    .mouse {
        width: 26px;
        height: 42px;
        border: 2px solid var(--hero-muted);
        border-radius: 20px;
        position: relative;
    }
    
    .wheel {
        width: 2px;
        height: 6px;
        background-color: var(--hero-accent);
        position: absolute;
        top: 8px;
        left: 50%;
        transform: translateX(-50%);
        border-radius: 2px;
        animation: scrollWheel 2s infinite;
    }
    
    @keyframes scrollWheel {
        0% { transform: translate(-50%, 0); opacity: 1; }
        100% { transform: translate(-50%, 15px); opacity: 0; }
    }
    
    .fade-in {
        opacity: 0;
        transform: translateY(30px);
        animation: fadeInUp 0.8s ease forwards;
    }
    
    .hero-title.fade-in { animation-delay: 0.2s; }
    .hero-description.fade-in { animation-delay: 0.4s; }
    .hero-actions.fade-in { animation-delay: 0.6s; }
    
    @keyframes fadeInUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    @media (max-width: 991px) {
        .hero-title { font-size: 3.5rem; }
        .hero-container { padding: 0 30px; }
    }
    
    @media (max-width: 768px) {
        .hero-modern-section { padding-top: 100px; text-align: center; }
        .hero-content { margin: 0 auto; }
        .hero-title { font-size: 2.8rem; }
        .hero-description { margin-left: auto; margin-right: auto; }
        .hero-actions { justify-content: center; }
    }

    /* ================= Achievements / Stats Section ================= */
    .achievements-section {
        background-color: #050505;
        padding: 80px 0;
        border-bottom: 1px solid rgba(255,255,255,0.03);
    }
    .achievements-grid {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-around;
        gap: 40px;
        text-align: center;
    }
    .achievement-card {
        flex: 1;
        min-width: 200px;
    }
    .achievement-number {
        font-size: 3.5rem;
        font-weight: 900;
        color: var(--hero-accent);
        margin-bottom: 10px;
        font-family: Arial, sans-serif;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
    }
    .achievement-label {
        font-size: 1.1rem;
        color: #a0a0a0;
        font-weight: bold;
    }

    /* ================= Services Section (NEW DESIGN - LTR) ================= */
    .cpoint-services-section {
        background-color: #000000;
        color: #ffffff;
        padding: 120px 0;
        position: relative;
        overflow: hidden;
    }
    .cpoint-services-header {
        text-align: center;
        margin-bottom: 80px;
        position: relative;
    }
    .cpoint-services-header h2 {
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        font-weight: 900;
        margin-bottom: 20px;
        color: #ffffff;
    }
    .cpoint-services-header p {
        font-size: clamp(1rem, 1.5vw, 1.2rem);
        color: #a0a0a0;
        line-height: 1.6;
        max-width: 700px;
        margin: 0 auto;
    }
    .header-red-dot {
        position: absolute;
        top: -20px;
        left: 15%; /* LTR Adaptation */
        width: 14px;
        height: 14px;
        background-color: #ff3131;
        border-radius: 50%;
    }
    .cpoint-services-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 60px 40px;
        max-width: 1200px;
        margin: 0 auto;
        position: relative;
    }
    /* Staggering */
    .cpoint-service-item:nth-child(2) { margin-top: 100px; }
    .cpoint-service-item:nth-child(5) { margin-top: -60px; }
    .cpoint-service-item:nth-child(4) { margin-top: -40px; }

    .cpoint-service-item {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        padding-bottom: 30px;
    }
    .cpoint-service-item::after {
        content: '';
        position: absolute;
        right: -20px;
        top: 20%;
        height: 60%;
        width: 1px;
        background: rgba(255, 255, 255, 0.05);
    }
    .cpoint-service-item:nth-child(3n)::after { display: none; }
    
    .cpoint-svc-num {
        position: absolute;
        top: 0;
        left: 0;
        font-size: 1.2rem;
        font-weight: 700;
        color: #ffffff;
    }
    .cpoint-svc-img {
        width: 100%;
        height: 220px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 20px;
        margin-top: 30px;
    }
    .cpoint-svc-img img {
        max-width: 90%;
        max-height: 100%;
        object-fit: contain;
        transition: transform 0.4s ease;
    }
    .cpoint-svc-content {
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: flex-start; /* LTR Adaptation */
        text-align: left;
    }
    .cpoint-svc-title-row {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        gap: 10px;
        margin-bottom: 5px;
        width: 100%;
    }
    .cpoint-svc-title-row h3 {
        font-size: 1.3rem;
        font-weight: 800;
        color: #ffffff;
        margin: 0;
    }
    .item-red-dot {
        width: 8px;
        height: 8px;
        background-color: #ff3131;
        border-radius: 50%;
    }
    .cpoint-svc-content p {
        font-size: 0.85rem;
        color: #888888;
        margin: 0;
    }

    /* ================= Portfolio Grid Section ================= */
    .cpoint-portfolio-section {
        background-color: #ffffff;
        padding: 100px 0 0 0;
    }
    .cpoint-portfolio-header {
        text-align: center;
        margin-bottom: 60px;
        padding: 0 20px;
    }
    .cpoint-portfolio-header h2 {
        font-size: clamp(2.5rem, 4vw, 3.5rem);
        font-weight: 900;
        color: #000000;
        margin-bottom: 15px;
    }
    .cpoint-portfolio-header p {
        font-size: 1.1rem;
        color: #666666;
        max-width: 600px;
        margin: 0 auto;
        line-height: 1.6;
    }
    .cpoint-portfolio-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-auto-rows: 300px;
        gap: 0;
        width: 100%;
    }
    .cpoint-project-item {
        position: relative;
        display: block;
        overflow: hidden;
        text-decoration: none;
    }
    .cpoint-project-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
        display: block;
    }
    .cpoint-project-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
        display: flex;
        align-items: flex-end;
        padding: 30px;
        opacity: 0;
        transition: opacity 0.4s ease;
    }
    .cpoint-project-overlay h3 {
        color: #fff;
        font-size: 1.5rem;
        font-weight: bold;
        transform: translateY(20px);
        transition: transform 0.4s ease;
    }
    .cpoint-project-item:hover img { transform: scale(1.08); }
    .cpoint-project-item:hover .cpoint-project-overlay { opacity: 1; }
    .cpoint-project-item:hover .cpoint-project-overlay h3 { transform: translateY(0); }

    /* Collage Layout Pattern */
    .cpoint-project-item:nth-child(6n + 1) { grid-column: span 1; grid-row: span 1; }
    .cpoint-project-item:nth-child(6n + 2) { grid-column: span 2; grid-row: span 2; }
    .cpoint-project-item:nth-child(6n + 3) { grid-column: span 1; grid-row: span 1; }
    .cpoint-project-item:nth-child(6n + 4) { grid-column: span 1; grid-row: span 1; }
    .cpoint-project-item:nth-child(6n + 5) { grid-column: span 1; grid-row: span 1; }
    .cpoint-project-item:nth-child(6n + 6) { grid-column: span 4; grid-row: span 1; }

    @media (max-width: 768px) {
        .cpoint-portfolio-grid { grid-template-columns: repeat(2, 1fr); grid-auto-rows: 200px;}
        .cpoint-project-item:nth-child(n) { grid-column: span 1; grid-row: span 1; }
        .cpoint-project-item:nth-child(6n + 6) { grid-column: span 2; }
    }

    /* ================= Blog & Contact Section ================= */
    .blog-home-section { padding: 100px 0; background: #fafafa; }
    .contact-section { padding: 100px 0; background: #111; color: #fff; position: relative; }
</style>

<main>

    <!-- ========================= Hero Section ========================== -->
    <%
        var seo = globalSeo;
        var heroBgStyle = (seo && seo.heroBackgroundImage) ? `style="background-image: url('${assetPath(seo.heroBackgroundImage)}');"` : "";
    %>
    <section class="hero-modern-section" <%- heroBgStyle %>>
        <div class="hero-overlay"></div>

        <div class="container hero-container">
            <div class="hero-content">
                <p class="hero-eyebrow fade-in">
                    <%= seo && seo.heroSmallTitleEn ? seo.heroSmallTitleEn : 'Creative starts with a point' %>
                </p>
                <h1 class="hero-title fade-in">
                    <%- (seo && seo.heroMainTitleEn ? seo.heroMainTitleEn : 'Full Service Creative <br> & Marketing Agency').replace(/\n/g, '<br>') %>
                </h1>
                <p class="hero-description fade-in">
                    <%= seo && seo.heroDescriptionEn ? seo.heroDescriptionEn : 'We believe that clarity of vision is the basis of every successful project.' %>
                </p>
                <div class="hero-actions fade-in">
                    <a href="#services" class="btn-hero-pill">
                        <%= seo && seo.heroBtnTextEn ? seo.heroBtnTextEn : 'Explore Services' %>
                        <i class="ri-arrow-right-line"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="hero-scroll-indicator">
            <div class="mouse"><div class="wheel"></div></div>
            <span>Scroll</span>
        </div>
    </section>

    <!-- ========================= Stats / Achievements Section ========================== -->
    <% if (typeof stats !== 'undefined' && stats && stats.length) { %>
    <section class="achievements-section">
        <div class="container">
            <div class="achievements-grid" data-gsap="fade-up">
                <% stats.forEach(function(stat) { %>
                    <div class="achievement-card">
                        <div class="achievement-number">
                            <span class="stat-number" data-target="<%= stat.value %>"><%= stat.value %></span>
                            <% if (stat.suffix_en) { %>
                                <span class="stat-suffix"><%= stat.suffix_en %></span>
                            <% } %>
                        </div>
                        <p class="achievement-label"><%= stat.label_en %></p>
                    </div>
                <% }); %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- ========================= Partners Section ========================== -->
    <section id="partners" class="partners-section" style="padding: 60px 0; background:#f9f9f9;">
        <div class="container">
            <div class="partners-header" data-gsap="fade-up" style="text-align:center; margin-bottom:40px;">
                <h2 class="partners-title" style="font-size:1.8rem; font-weight:bold; color:#000;">Proud of our work and our partnerships.</h2>
            </div>
            <div class="partners-grid" style="display:flex; justify-content:center; gap:30px; flex-wrap:wrap; align-items:center;">
                <% if (partners && partners.length > 0) { %>
                    <% partners.forEach(function(partner) { %>
                        <div class="partner-item" data-gsap="fade-up">
                            <img src="<%= assetPath(partner.logo || '') %>" alt="<%= partner.name || '' %>" width="150" style="filter:grayscale(100%); opacity:0.7; transition:all 0.3s;">
                        </div>
                    <% }); %>
                <% } else { %>
                    <div class="partner-item" data-gsap="fade-up">
                        <p style="color:#444; font-size:0.9rem;">No partners added yet.</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>

    <!-- ========================= Services Section (LTR) ========================== -->
    <section id="services" class="cpoint-services-section">
        <div class="container" style="max-width: 1400px; padding: 0 40px;">
            <div class="cpoint-services-header" data-gsap="fade-up">
                <div class="header-red-dot"></div>
                <h2>Our Services</h2>
                <p>Integrated solutions starting from a clear point. Every service is built on strategic decisions to create a cohesive creative system.</p>
            </div>

            <div class="cpoint-services-grid">
                <% var servicesList = (typeof services !== 'undefined' && services) ? services : []; %>
                <% if (servicesList.length) { %>
                    <% servicesList.forEach(function(service, index) { %>
                        <div class="cpoint-service-item" data-gsap="fade-up">
                            <span class="cpoint-svc-num"><%= (index + 1).toString().padStart(2, '0') %></span>
                            <div class="cpoint-svc-img">
                                <% if (service.image) { %>
                                    <img src="<%= assetPath(service.image) %>" alt="<%= service.title_en || '' %>" loading="lazy">
                                <% } %>
                            </div>
                            <div class="cpoint-svc-content">
                                <div class="cpoint-svc-title-row">
                                    <div class="item-red-dot"></div>
                                    <h3><%= service.title_en || service.title_ar || 'Service Title' %></h3>
                                </div>
                                <p><%= service.description_en || 'Service Description' %></p>
                            </div>
                        </div>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </section>

    <!-- ========================= Portfolio Section ========================== -->
    <section id="portfolio" class="cpoint-portfolio-section">
        <div class="cpoint-portfolio-header" data-gsap="fade-up">
            <h2>Latest Projects</h2>
            <p>Turning ideas into tangible reality... explore our latest creative work.</p>
        </div>

        <div class="cpoint-portfolio-grid">
            <% if (projects && projects.length > 0) { %>
                <% projects.forEach(function(project) { %>
                    <a href="<%= project.externalLink || '/portfolio/' + project.id %>" class="cpoint-project-item">
                        <% if (project.image) { %>
                            <img src="<%= assetPath(project.image) %>" alt="<%= project.title_en || '' %>" loading="lazy">
                        <% } %>
                        <div class="cpoint-project-overlay">
                            <h3><%= project.title_en || 'Creative Project' %></h3>
                        </div>
                    </a>
                <% }); %>
            <% } %>
        </div>
    </section>

    <!-- ========================= Blog Section ========================== -->
    <section id="blog" class="blog-home-section">
        <div class="container">
            <div class="section-header" style="text-align: center; margin-bottom: 3rem;">
                <h2 class="section-title" style="font-size: 2.5rem; color:#000;">Latest Articles</h2>
            </div>
            <div class="blog-grid" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:30px;">
                <% if (posts && posts.length > 0) { %>
                    <% posts.forEach(function(post) { %>
                        <article class="blog-card" style="background:#fff; border-radius:15px; overflow:hidden; box-shadow:0 10px 30px rgba(0,0,0,0.05);">
                            <div class="blog-content" style="padding:25px;">
                                <span style="color:#ff3131; font-size:0.85rem;"><%= post.date || '' %></span>
                                <h3 style="margin:10px 0; color:#000;"><%= post.title_en || post.title || '' %></h3>
                                <a href="/blog/<%= post.id %>" style="color:#000; font-weight:bold; text-decoration:none;">Read More <i class="ri-arrow-right-line"></i></a>
                            </div>
                        </article>
                    <% }); %>
                <% } %>
            </div>
        </div>
    </section>

    <!-- ========================= Contact Section ========================== -->
    <section id="contact" class="contact-section">
        <div class="container">
            <div class="contact-grid" style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:60px;">
                <div class="contact-info">
                    <h2 style="font-size:2.5rem; margin-bottom:20px;">Start a New Journey</h2>
                    <p style="color:#aaa; line-height:1.6;">We are here to listen to your ideas and transform them into visual impact. Contact us today.</p>
                </div>
                <div class="contact-form-wrapper">
                    <form action="/contact" method="POST" class="contact-form" style="display:flex; flex-direction:column; gap:20px;">
                        <input type="text" name="name" placeholder="Full Name" required style="width:100%; padding:15px; background:#1a1a1a; border:1px solid #333; color:#fff; border-radius:8px;">
                        <input type="email" name="email" placeholder="Email Address" required style="width:100%; padding:15px; background:#1a1a1a; border:1px solid #333; color:#fff; border-radius:8px;">
                        <textarea name="message" rows="4" placeholder="Project Details" style="width:100%; padding:15px; background:#1a1a1a; border:1px solid #333; color:#fff; border-radius:8px;"></textarea>
                        <button type="submit" style="background:#ff3131; color:#fff; padding:15px; border:none; border-radius:8px; font-weight:bold; cursor:pointer;">Send Request</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

</main>

<%- include('partials/footer', { isEn: isEn }) %>